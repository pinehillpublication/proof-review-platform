{
  "name": "pinehill-proof-review-backend",
  "version": "1.0.0",
  "description": "Backend API for Pinehill Publications Author Proof Review Platform",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "migrate": "node --loader tsx ./src/database/migrate.ts",
    "migrate:rollback": "node --loader tsx ./src/database/rollback.ts",
    "seed": "node --loader tsx ./src/database/seed.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-validator": "^7.0.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.1.2",
    "multer": "^1.4.5-lts.1",
    "pg": "^8.11.3",
    "pdfkit": "^0.13.0",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1",
    "xlsx": "^0.18.5",
    "nodemailer": "^6.9.7"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
